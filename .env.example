# ---------------------------------------------------------------------------
# qa-service environment variables
# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored; never commit real keys.
# ---------------------------------------------------------------------------

# --- LLM (NVIDIA NIM, OpenAI-compatible endpoint) ---------------------------
# Get a free API key at https://build.nvidia.com/
LLM_PROVIDER=nvidia
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.1-8b-instruct
LLM_API_KEY=replace-me-with-nvidia-key
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512

# --- Embedding (local sentence-transformers, no key required) ---------------
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store (Chroma) --------------------------------------------------
# A filesystem path uses an embedded persistent ChromaDB (no separate service).
# docker-compose sets this to /app/.chroma (backed by a named volume).
# An http:// URL would instead connect to a remote Chroma server.
VECTOR_STORE_URL=./.chroma

# --- Chunking ---------------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=4

# --- Server -----------------------------------------------------------------
LOG_LEVEL=INFO
APP_PORT=8000
